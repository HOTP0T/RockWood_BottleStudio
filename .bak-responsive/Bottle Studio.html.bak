        h('input',{ type:'number', value:this.state.quantity, min:1,
          onChange:ev=>this.setField({quantity:Math.max(1,parseInt(ev.target.value||'1',10))}),
          style:{ width:'100%', padding:'11px 13px', borderRadius:'6px', border:'1px solid '+C.line, background:'#fff', fontFamily:this.mono, fontSize:'15px', color:C.ink } })),
      // secondary readouts
      h('div',{ style:{ background:C.card, border:'1px solid '+C.line, borderRadius:'8px', padding:'4px 14px 10px', marginBottom:'16px' } },
        h('div',{ style:{ fontSize:'11px', fontWeight:700, letterSpacing:'.08em', textTransform:'uppercase', color:C.sub, padding:'12px 0 4px' } }, 'Engineering readouts'),
        ro('Brimful', this.fmt(e.brimfulMl,0)+' ml'),
        ro('Min wall', this.fmt(cv(e.minWallMm/10), u==='mm'?2:3)+' '+u + (e.minWallMm<1?'  !':'')),
        ro('Wrap-label area', this.fmt(e.wrapLabelCm2,0)+' cm\u00b2'),
        ro('Tol. height', '\u00b1'+e.tol.heightMm.toFixed(2)+' mm'),
        ro('Tol. \u00d8', '\u00b1'+e.tol.diaMm.toFixed(2)+' mm'),
        ro('Tol. capacity', '\u00b1'+e.tol.capPct+'%')
      ),
      // order summary
      h('div',{ style:{ background:C.ink, color:'#fff', borderRadius:'8px', padding:'4px 16px 14px' } },
        h('div',{ style:{ fontSize:'11px', fontWeight:700, letterSpacing:'.08em', textTransform:'uppercase', color:C.A, padding:'13px 0 4px' } }, 'Order'),
        this.orderRow('Unit cost', this.money(e.order.unitCost)),
        this.orderRow('Tooling / unit', this.money(e.order.toolingPerUnit)),
        this.orderRow('All-in / bottle', this.money(e.order.unitAllIn), true),
        this.orderRow('Order total', this.money(e.order.totalOrder)),
        e.order.belowMoq?h('div',{ style:{ display:'flex', gap:'7px', marginTop:'10px', fontSize:'11.5px', color:'#E8B45A', lineHeight:1.4 } },
          h('span',null,'!'), 'Below MOQ of '+this.fmt(e.order.moq)+' for '+this.MATERIALS.find(m=>m.key===this.state.material).label+'.'):null
      )
    );
  }
  orderRow(label,val,big) {
    const h=this.h;
    return h('div',{ style:{ display:'flex', justifyContent:'space-between', alignItems:'baseline', padding:big?'9px 0':'6px 0', borderTop:big?'1px solid rgba(255,255,255,.14)':'none' } },
      h('span',{ style:{ fontSize:big?'13px':'12.5px', color:big?'#fff':'rgba(255,255,255,.7)', fontWeight:big?600:400 } }, label),
      h('span',{ style:{ fontFamily:this.mono, fontSize:big?'17px':'13px', color:'#fff', fontWeight:big?700:500 } }, val));
  }
  hintMore() {
    const h=this.h, C=this.C;
    return h('button',{ 'data-press':'1', onClick:()=>this.setState({advanced:true}),
      style:{ marginTop:'4px', fontSize:'12.5px', color:C.A, fontWeight:600, display:'flex', gap:'6px', alignItems:'center' } },
      '+ Show advanced parameters');
  }
}

      onMouseEnter:show, onMouseLeave:hide, onFocus:show, onBlur:hide,
      onClick:(e)=>{ e.preventDefault(); const open=this.state.tip&&this.state.tip.text===txt; if(open) this.setState({tip:null}); else show(e); },
      style:{ width:'15px', height:'15px', borderRadius:'50%', border:'1px solid '+C.line, color:C.faint,
        fontSize:'9.5px', fontWeight:700, display:'inline-grid', placeItems:'center', lineHeight:1, flex:'0 0 auto', cursor:'help' } }, '?');
  }
  renderTip() {

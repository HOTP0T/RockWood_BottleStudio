  }
  wallSlider() {
    const h=this.h, C=this.C, v=this.state.wall;
    return h('div',{ style:{ marginBottom:'18px' } },
      h('div',{ style:{ display:'flex', justifyContent:'space-between', marginBottom:'8px' } },
        h('span',{ style:{ display:'inline-flex', alignItems:'center', gap:'6px' } },
          h('span',{ style:{ fontSize:'13.5px', fontWeight:500, color:C.ink } }, 'Wall profile'), this.helpDot('wall')),
        h('span',{ style:{ fontFamily:this.mono, fontSize:'12.5px', color:C.A, fontWeight:600 } }, v===0?'straight':v>0?'+'+v.toFixed(2)+' convex':v.toFixed(2)+' concave')),
      h('input',{ type:'range', min:-1, max:1, step:0.05, value:v,
        onChange:ev=>this.setField({wall:parseFloat(ev.target.value)}), style:{ width:'100%' } }),
      h('div',{ style:{ display:'flex', justifyContent:'space-between', fontSize:'10.5px', color:C.faint, marginTop:'4px' } },
        h('span',null,'concave'), h('span',null,'convex'))
    );
  }
  tabSize() {
    const h=this.h, adv=this.state.advanced;
    return h('div',null,
      this.numRow('shoulderWidth','Body \u00d8 (at shoulder)',{tag:'drag \u2194'}),
      this.numRow('body','Body height',{tag:'drag \u2195'}),
      this.numRow('baseWidth','Base \u00d8',{tag:'drag \u2194'}),
      adv?h('div',null,
        this.state.shape==='oval'?this.numRow('bodyDepth','Body depth (Y)'):null,
        this.numRow('shoulderHeight','Shoulder height',{tag:'drag \u2195'}),
        this.sliderRow('shoulderRadius','Shoulder roundness',v=>v.toFixed(2),{ends:['sharp','round']}),
        this.wallSlider(),
        this.numRow('wallThickness','Wall thickness')
      ):this.hintMore()
    );
  }
  tabFinish() {
    const h=this.h, C=this.C, adv=this.state.advanced;
    const cur=this.state.finish;
    return h('div',null,
      h('div',{ style:{ fontSize:'12.5px', fontWeight:600, color:C.sub, marginBottom:'9px' } }, 'Standard finish'),
      h('div',{ style:{ display:'flex', flexDirection:'column', gap:'7px', marginBottom:'18px' } },
        this.FINISHES.map(f=>{ const a=cur===f.key, compat=f.closures.includes(this.state.closure);
          return h('button',{ key:f.key, 'data-press':'1', onClick:()=>this.setFinish(f.key),
            style:{ display:'flex', justifyContent:'space-between', alignItems:'center', padding:'11px 13px', borderRadius:'6px',
              border:'1px solid '+(a?C.A:C.line), background:a?'#fff':C.card, textAlign:'left' } },
            h('span',null,
              h('div',{ style:{ fontSize:'13.5px', fontWeight:600, color:C.ink } }, f.name+'  ',
                !compat?h('span',{ style:{ color:C.warn, fontSize:'11px' } }, ' ! closure'):null),
              h('div',{ style:{ fontSize:'11px', color:C.sub } }, f.style+' \u00b7 '+f.std)),
            h('span',{ style:{ fontFamily:this.mono, fontSize:'10.5px', color:C.faint, textAlign:'right' } }, 'T'+f.T+' I'+f.I)
          ); })
      ),
      this.numRow('mouth','Thread \u00d8 (T)',{tag:'drag \u2194'}),
      this.numRow('finishHeight','Finish height (H)',{tag:'drag \u2195'}),
      this.numRow('neckWidth','Neck \u00d8',{tag:'drag \u2194'}),
      this.numRow('neck','Neck height',{tag:'drag \u2195'}),
      adv?this.numRow('bore','Bore / throat \u00d8 (I)'):this.hintMore()
    );
  }
  tabBase() {
    const h=this.h, adv=this.state.advanced;
    return h('div',null,
      this.numRow('baseWidth','Base \u00d8',{tag:'drag \u2194'}),
      this.numRow('slug','Base glass thickness',{tag:'drag \u2195'}),
      this.sliderRow('heelRadius','Heel roundness',v=>v.toFixed(2),{ends:['sharp','round']}),
      this.numRow('punt','Push-up (punt) depth'),
      adv?null:this.hintMore()
    );
  }
  tabProduction(e) {
    const h=this.h, C=this.C, adv=this.state.advanced;
    const seg=(label,opts,val,onPick,helpKey)=>h('div',{ style:{ marginBottom:'16px' } },
      h('div',{ style:{ display:'flex', alignItems:'center', gap:'6px', fontSize:'12.5px', fontWeight:600, color:C.sub, marginBottom:'8px' } }, label, helpKey?this.helpDot(helpKey):null),
      h('div',{ style:{ display:'flex', gap:'6px', flexWrap:'wrap' } },
        opts.map(o=>h('button',{ key:o.v, 'data-press':'1', onClick:()=>onPick(o.v),
          style:{ padding:'8px 12px', borderRadius:'999px', border:'1px solid '+(val===o.v?C.A:C.line),
            background:val===o.v?'#fff':C.card, color:val===o.v?C.A:C.sub, fontSize:'12.5px', fontWeight:600 } }, o.l))));
    const ro=(label,val)=>h('div',{ style:{ display:'flex', justifyContent:'space-between', padding:'8px 0', borderBottom:'1px solid '+C.lineSoft } },

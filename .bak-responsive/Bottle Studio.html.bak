    );
  }
  sliderRow(key, label, fmtFn, opts={}) {
    const h=this.h, C=this.C, r=this.RANGES[key], st=this.STEPS[key], v=this.state.dimensions[key];
    return h('div',{ key, style:{ marginBottom:'18px' } },
      h('div',{ style:{ display:'flex', justifyContent:'space-between', marginBottom:'8px' } },
        h('span',{ style:{ display:'inline-flex', alignItems:'center', gap:'6px' } },
          h('span',{ style:{ fontSize:'13.5px', fontWeight:500, color:C.ink } }, label), this.helpDot(key)),
        h('span',{ style:{ fontFamily:this.mono, fontSize:'12.5px', color:C.A, fontWeight:600 } }, fmtFn(v))),
      h('input',{ type:'range', min:r[0], max:r[1], step:st, value:v,
        onChange:ev=>this.setDim(key, parseFloat(ev.target.value)), style:{ width:'100%' } }),
      opts.ends?h('div',{ style:{ display:'flex', justifyContent:'space-between', fontSize:'10.5px', color:C.faint, marginTop:'4px' } },
        h('span',null,opts.ends[0]), h('span',null,opts.ends[1])):null

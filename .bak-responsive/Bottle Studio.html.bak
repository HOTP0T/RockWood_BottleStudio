    const vw=(typeof window!=='undefined'?window.innerWidth:1200);
    const x=this.clamp(t.x, 126, vw-126);
    return h('div',{ role:'tooltip', style:{ position:'fixed', left:x+'px', top:(t.y-10)+'px', transform:'translate(-50%,-100%)',
      width:'234px', maxWidth:'74vw', background:C.ink, color:'#F4F0E7', padding:'11px 13px', borderRadius:'9px',
      fontSize:'12px', lineHeight:1.5, zIndex:90, boxShadow:'0 18px 44px -12px rgba(0,0,0,.55)', pointerEvents:'none',
      fontFamily:'\'Hanken Grotesk\',sans-serif', fontWeight:400 } },
      t.text,
      h('span',{ style:{ position:'absolute', bottom:'-5px', left:'50%', transform:'translateX(-50%) rotate(45deg)', width:'10px', height:'10px', background:C.ink } })
    );
  }
  // control widgets
  numRow(key, label, opts={}) {
    const h=this.h, C=this.C, r=this.RANGES[key], st=this.STEPS[key];
    const u=this.state.units, cm=u==='mm', uf=cm?10:1;
    const v=this.state.dimensions[key];
    const dispV=this.toDisp(v);
    const dec = cm ? 0 : 2;
    const set=(nv)=>this.setDim(key, this.fromDisp(nv));
    return h('div',{ key, style:{ marginBottom:'16px' } },
      h('div',{ style:{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:'7px' } },
        h('span',{ style:{ display:'inline-flex', alignItems:'center', gap:'6px' } },
          h('span',{ style:{ fontSize:'13.5px', fontWeight:500, color:C.ink } }, label), this.helpDot(key)),
        opts.tag?h('span',{ style:{ fontFamily:this.mono, fontSize:'10px', color:C.faint } }, opts.tag):null),
      h('div',{ style:{ display:'flex', alignItems:'stretch', border:'1px solid '+C.line, borderRadius:'6px', overflow:'hidden', background:'#fff' } },
        h('button',{ 'data-press':'1', 'aria-label':'decrease', onClick:()=>set(this.toDisp(this.clamp(v-st,r[0],r[1]))),
          style:{ width:'40px', fontSize:'18px', color:C.sub, borderRight:'1px solid '+C.line } }, '\u2212'),
        h('input',{ type:'number', value:Math.round(dispV*100)/100, step:st*uf,
          onChange:ev=>{ const nv=parseFloat(ev.target.value); if(!isNaN(nv)) set(nv); },
          style:{ flex:'1', minWidth:0, textAlign:'center', border:'none', fontFamily:this.mono, fontSize:'15px', color:C.ink, padding:'10px 4px', fontVariantNumeric:'tabular-nums' } }),
        h('span',{ style:{ display:'grid', placeItems:'center', padding:'0 10px', fontFamily:this.mono, fontSize:'11px', color:C.faint, borderLeft:'1px solid '+C.line } }, u),
        h('button',{ 'data-press':'1', 'aria-label':'increase', onClick:()=>set(this.toDisp(this.clamp(v+st,r[0],r[1]))),
          style:{ width:'40px', fontSize:'18px', color:C.sub, borderLeft:'1px solid '+C.line } }, '+')
